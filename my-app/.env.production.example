# ==============================================================================
# LifeByDorm — Production Environment Variables
# ==============================================================================
# Set these in your hosting platform (Vercel, AWS, etc.)
# Do NOT create a .env.production file in the repo
# ==============================================================================

# --- Server ---
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/lifebydorm
ACCESS_TOKEN_SECRET=
GOOGLE_CLIENT_ID=
EMAIL_USER=
EMAIL_PASS=
ADMIN_EMAILS=
FRONTEND_URL=https://www.lifebydorm.ca
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=
NODE_ENV=production

# --- Client (VITE_ prefix — public, set in Vercel build settings) ---
VITE_API_BASE=https://your-api-domain.com
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_MAPS_API_KEY=
