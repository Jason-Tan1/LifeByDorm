# Frontend environment variables
# Copy this file to `client/.env` for local values used by the frontend.

# Backend API base URL used by the browser outside localhost/dev proxy setups.
VITE_API_BASE=https://api.yourdomain.com

# Google OAuth client ID exposed to the frontend.
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google Maps API key used on dorm detail pages.
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
