# ==============================================================================
# LifeByDorm — Client Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control!
# ==============================================================================
# NOTE: All VITE_ variables are embedded into the client bundle at build time
# and are visible to end users. Never put secrets here.
# ==============================================================================

# Production API URL (leave empty for local dev — Vite proxy handles it)
VITE_API_BASE=

# Google OAuth Client ID (must match the server's GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google Maps Embed API Key (restrict to Maps Embed API in Google Cloud Console)
VITE_GOOGLE_MAPS_API_KEY=

# Google AdSense Publisher ID (e.g. ca-pub-1234567890123456)
VITE_GOOGLE_ADSENSE_CLIENT_ID=
