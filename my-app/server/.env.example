# Backend environment variables
# Copy this file to `server/.env` and fill in the values for your environment.

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/lifebydorm

# JWT signing secret
ACCESS_TOKEN_SECRET=your-super-secret-jwt-key-at-least-32-characters

# Google OAuth client ID
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Comma-separated admin email addresses
ADMIN_EMAILS=admin@example.com

# Allowed frontend origin for CORS
FRONTEND_URL=http://localhost:5173

# Email login / verification sender
EMAIL_USER=
EMAIL_PASS=

# AWS S3 configuration for uploads
AWS_BUCKET_NAME=your-bucket-name
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Runtime settings
NODE_ENV=development
PORT=3000
NODE_OPTIONS=--max-old-space-size=4096

# Optional seed/admin defaults
ADMIN_DEFAULT_PASSWORD=Admin123!
